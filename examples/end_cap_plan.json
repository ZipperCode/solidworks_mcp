        "thickness": 10,
        "center_hole_diameter": 20,
        "bolt_circle_diameter": 70,
        "bolt_hole_diameter": 8,
        "bolt_hole_count": 6
      }
    },
    {
      "id": "material",
      "op": "assign_material",
      "description": "Assign production baseline material.",
      "parameters": {
        "material": "Plain Carbon Steel"
      }
    },
    {
      "id": "drawing",
      "op": "make_drawing",
      "description": "Create drawing views and trusted end-cap dimensions.",
      "parameters": {}
    }
  ]
}
