{
  "name": "end_cap",
  "description": "Controlled circular end cap production baseline.",
  "units": "mm",
  "metadata": {
    "part_number": "ECP-100-06",
    "revision": "A",
    "author": "solidworks_mcp"
  },
  "output_formats": ["sldprt", "step", "stl"],
  "drawing_profile": {
    "enabled": true,
    "sheet_format": "A3",
    "projection": "third_angle",
    "include_isometric": true,
    "include_basic_dimensions": true,
