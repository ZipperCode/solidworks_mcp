{
  "name": "center_hole_plate",
  "units": "mm",
  "metadata": {
    "description": "Controlled rectangular center-hole plate: 100 x 60 x 12 mm with a 24 mm center through hole."
  },
  "output_formats": ["sldprt", "step", "stl"],
  "drawing_profile": {
    "enabled": true,
    "sheet_format": "A3",
    "projection": "third_angle",
    "include_isometric": true,
    "include_basic_dimensions": true,
    "export_formats": ["pdf", "dwg"]
  },
  "operations": [
    {
      "id": "center_hole_plate",
      "op": "create_center_hole_plate",
      "description": "Create the controlled rectangular center-hole plate.",
      "parameters": {
        "length": 100,
        "width": 60,
        "thickness": 12,
        "hole_diameter": 24
      }
    },
    {
      "id": "material",
      "op": "assign_material",
      "description": "Assign a common steel material.",
      "parameters": {
        "material": "Plain Carbon Steel"
      }
    },
    {
      "id": "drawing",
      "op": "make_drawing",
      "description": "Request drawing outputs with trusted dimensions and hole callout.",
      "parameters": {}
    }
  ]
}
